# Bot 設定
AGENT_NAME=claude               # エージェント名
COPILOT_MODEL=claude-sonnet-4.6 # 使用する AI モデル (claude-opus-4.6(3x), claude-sonnet-4.6(1x), claude-haiku-4.5(0.33x) など)
REASONING_EFFORT=               # 推論レベル (low/medium/high, 空=モデルのデフォルト)

# タイムアウト設定
WAIT_TIMEOUT_MS=600000          # メッセージ待機タイムアウト (default: 10min)
SESSION_TIMEOUT_MS=3600000      # セッションタイムアウト (default: 1hour)

# ディレクトリ設定
WORKSPACE_DIR=./workspace       # AI の作業ディレクトリ
TEMPORARY_DIR=./tmp             # 添付画像等の一時保存先
PLUGINS_DIR=                     # スキルディレクトリ (空={WORKSPACE_DIR}/skills)
PROMPTS_DIR=                    # プロンプトディレクトリ (空={WORKSPACE_DIR}/.github/prompts)

# 権限設定
# 自動承認する操作 (カンマ区切り: shell,write,read,url,mcp,custom-tool / *=全て自動承認)
PERMISSION_AUTO_APPROVE=*
# ユーザー応答タイムアウト (default: 120s)
USER_RESPONSE_TIMEOUT_MS=120000

# GitHub
# トークンは https://github.com/settings/personal-access-tokens/new で取得 (Copilot Chat, Copilot Requests 権限が必要)
GITHUB_TOKEN=your_github_token_here

# Discord
# トークンは https://discord.com/developers/applications で取得 (Privileged Gateway Intents: Message Content Intent を ON にする)
DISCORD_BOT_TOKEN=your_bot_token_here
